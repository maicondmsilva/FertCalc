# =============================================================================
# FertCalc Pro — Variáveis de Ambiente
# =============================================================================
# Copie este arquivo para .env.local e preencha com seus valores reais.
# NUNCA commite o arquivo .env.local — ele já está no .gitignore.
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase — OBRIGATÓRIO
# Obtenha em: https://supabase.com → Seu projeto → Settings → API
# -----------------------------------------------------------------------------
VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# -----------------------------------------------------------------------------
# Google Gemini — Opcional (funcionalidades de IA)
# Obtenha em: https://aistudio.google.com/app/apikey
# -----------------------------------------------------------------------------
GEMINI_API_KEY=

# -----------------------------------------------------------------------------
# URL pública da aplicação — Opcional
# Usado em templates de e-mail e links de redirecionamento
# -----------------------------------------------------------------------------
APP_URL=https://sua-app.vercel.app
